        // — Slider (Kept original logic) —
        (function() {
            var track = document.getElementById('ioaTrack');
            if (!track) return;
            var dots = document.querySelectorAll('.ioa-dot');
            var current = 0;
            var total = 4;
            var duration = 5000;
            var timer;

            function goTo(index) {
                current = (index + total) % total;
                track.style.transform = 'translateX(-' + (current * 100) + '%)';
                dots.forEach(function(d) { d.classList.remove('active'); });
                dots[current].classList.add('active');
            }

            function autoPlay() {
                clearInterval(timer);
                timer = setInterval(function() { goTo(current + 1); }, duration);
            }

            document.getElementById('ioaPrev').addEventListener('click', function() {
                goTo(current - 1); autoPlay();
            });
            document.getElementById('ioaNext').addEventListener('click', function() {
                goTo(current + 1); autoPlay();
            });
            dots.forEach(function(dot) {
                dot.addEventListener('click', function() {
                    goTo(parseInt(this.getAttribute('data-index')));
                    autoPlay();
                });
            });

            autoPlay();
        })();

        // — Secciones (Always Open) —
        var textosSecciones = [
            'datos de identificacion',
            'estado general del bien',
            'ubicacion ioa',
            'contexto cultural',
            'descripcion morfologica',
            'tamano',
            'tecnica',
            'clasificacion estilistica',
            'clasificacion funcional'
        ];

        function normalizar(texto) {
            return texto.toLowerCase()
                .normalize('NFD')
                .replace(/[\u0300-\u036f]/g, '')
                .replace(/[^a-z0-9 ]/g, '')
                .trim();
        }

        var propiedades = document.querySelectorAll('.metadata dl div.property');
        propiedades.forEach(function (prop) {
            var dt = prop.querySelector('dt');
            if (dt) {
                var texto = normalizar(dt.textContent);
                textosSecciones.forEach(function (seccion) {
                    if (texto === seccion) {
                        prop.classList.add('ioa-seccion');
                    }
                });
            }
        });

        var secciones = document.querySelectorAll('.metadata dl div.property.ioa-seccion');
        secciones.forEach(function (seccion) {
            var dt = seccion.querySelector('dt');
            var textoOriginal = dt.textContent.trim();

            // Replace arrow with a dash and mark as open
            dt.innerHTML = textoOriginal + ' <span class="ioa-toggle">-</span>';
            seccion.classList.add('ioa-abierto');

            var siguiente = seccion.nextElementSibling;
            while (siguiente && !siguiente.classList.contains('ioa-seccion')) {
                // Ensure no "hidden" classes are applied
                siguiente.classList.remove('ioa-oculto');
                siguiente = siguiente.nextElementSibling;
            }

            // Removed the click event listener entirely so it stays static
        });

    });
    </script>

	</body>
</html>
