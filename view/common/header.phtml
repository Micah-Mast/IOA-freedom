	<script>
document.addEventListener('DOMContentLoaded', function () {
    const searchForm = document.querySelector('.main-header__search-form');
    const searchInput = document.getElementById('fulltext-search');
    const searchBtn = document.getElementById('search-submit');

    searchBtn.addEventListener('click', function (e) {
        if (!searchForm.classList.contains('open')) {
            // First click — just open the input, don't submit
            e.preventDefault();
            searchForm.classList.add('open');
            searchInput.value = '';
            searchInput.focus();
        }
        // If already open, allow normal form submission
    });

    // Close if user clicks outside
    document.addEventListener('click', function (e) {
        if (!searchForm.contains(e.target)) {
            searchForm.classList.remove('open');
            searchInput.value = '';
        }
    });
});
</script>
